{
  "manifest_version": 3,
  "name": "AKILI Security",
  "version": "1.0.0",
  "description": "AI security analysis for every page you visit",
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://api.akili.com.ng/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/eye48.svg",
      "128": "icons/eye128.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
