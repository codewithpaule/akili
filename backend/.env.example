GROQ_API_KEY=from console.groq.com
SERPAPI_KEY=from serpapi.com
JWT_SECRET=change-this-to-a-long-random-string
# Web application OAuth Client ID only — no secret, no redirect URI for sign-in button
GOOGLE_CLIENT_ID=
# Optional: HIBP_API_KEY=  GEMINI_API_KEY=
SHODAN_API_KEY=from shodan.io
VIRUSTOTAL_KEY=from virustotal.com
ALLOWED_ORIGINS=http://localhost:5501,http://127.0.0.1:5501
DATABASE_URL=sqlite:///./akili.db
GROQ_MODEL=llama-3.3-70b-versatile
CONTACT_EMAIL=hello@akili.io

# Transactional email (SMTP) — welcome, payment, renewal reminder, password reset
EMAIL_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=AKILI
# EMAIL_PROVIDER=smtp | sendgrid
# SENDGRID_API_KEY=
# Admin second factor (optional) — required on admin-login if set
# ADMIN_PIN=
# Cron: POST /api/v1/cron/renewal-reminders with header X-Cron-Secret
# CRON_SECRET=

# Paystack (https://dashboard.paystack.com) — NGN monthly Premium
# Use REAL keys from Dashboard → Settings → API Keys (placeholders pk_test_xxxx will NOT work)
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
# Dashboard → Plans → create ₦12,000/month plan → copy Plan Code
PAYSTACK_PREMIUM_PLAN_CODE=PLN_your_plan_code_here
FRONTEND_URL=http://localhost:5501

# Admin (bootstrap on API start — use admin-login.html, not public nav)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-this-admin-password

# Optional fallbacks if SerpAPI limit hit:
# GOOGLE_SEARCH_KEY=
# GOOGLE_SEARCH_CX=
