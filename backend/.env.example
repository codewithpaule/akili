# Required
GROQ_API_KEY=         # Get this at console.groq.com
SERPAPI_KEY=          # Get this at serpapi.com (used for person OSINT and agent web search)

# Optional but recommended
GEMINI_API_KEY=       # Free tier at aistudio.google.com — used as fallback if Groq is unavailable
SHODAN_API_KEY=       # Improves IP and port scan results
VIRUSTOTAL_KEY=       # Improves domain and file reputation checks

# Server
ALLOWED_ORIGINS=http://localhost:5501
SECRET_KEY=           # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DATABASE_URL=         # Leave blank to use SQLite (default). PostgreSQL URL for production.
ADMIN_ACCESS_KEY=     # Optional. Set to protect admin routes with a shared secret header.

JWT_SECRET=change-this-to-a-long-random-string
# Web application OAuth Client ID only — no secret, no redirect URI for sign-in button
GOOGLE_CLIENT_ID=
GROQ_MODEL=llama-3.3-70b-versatile
CONTACT_EMAIL=hello@akili.io

# Transactional email (SMTP) — welcome, payment, renewal reminder, password reset
EMAIL_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=AKILI
# EMAIL_PROVIDER=smtp | sendgrid
# SENDGRID_API_KEY=
# Admin second factor (optional) — required on admin-login if set
# ADMIN_PIN=
# Cron: POST /api/v1/cron/renewal-reminders with header X-Cron-Secret
# CRON_SECRET=

# Paystack (optional) — Billing and paid plans are disabled in this deployment.
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PREMIUM_PLAN_CODE=
FRONTEND_URL=http://localhost:5501

# Admin (bootstrap on API start — use admin-login.html, not public nav)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-this-admin-password

# Optional fallbacks if SerpAPI limit hit:
# GOOGLE_SEARCH_KEY=
# GOOGLE_SEARCH_CX=
